{
  "name": "@chemistry/crystallography-api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Crystal Structure Search Application",
  "license": "MIT",
  "author": {
    "name": "Volodymyr Vreshch",
    "url": "https://vreshch.com/"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/chemistry/crystallography.io.git"
  },
  "engines": {
    "node": ">=22.0.0",
    "npm": ">=10.0.0"
  },
  "workspaces": [
    "packages/libraries/*",
    "packages/containers/*"
  ],
  "scripts": {
    "build": "tsc -b",
    "test": "vitest run",
    "lint": "eslint 'packages/**/*.{ts,tsx}'",
    "format": "prettier --write 'packages/**/*.{ts,tsx}'",
    "format:check": "prettier --check 'packages/**/*.{ts,tsx}'",
    "dev": "npx tsx packages/containers/mock-server/src/index.ts & npx vite packages/containers/c14-web",
    "clean": "rimraf packages/**/dist coverage",
    "verify": "npm run build && npm run lint && npm run test"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^22.19.15",
    "eslint": "^10.0.3",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "nodemon": "^3.1.0",
    "prettier": "^3.8.1",
    "rimraf": "^5.0.0",
    "supertest": "^7.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.9.0",
    "typescript-eslint": "^8.57.0",
    "vitest": "^4.1.0"
  }
}
