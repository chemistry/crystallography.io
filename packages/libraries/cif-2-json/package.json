{
  "name": "@chemistry/cif-2-json",
  "version": "0.0.18",
  "type": "module",
  "description": "Tool for converting CIF to JSON and manipulate with content",
  "author": {
    "name": "Volodymyr Vreshch",
    "url": "https://vreshch.com/"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/vreshch/cif2json.git"
  },
  "main": "dist/cif-2-json.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/cif-2-json.js",
      "require": "./dist/cif-2-json.js"
    }
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "keywords": [
    "crystallography",
    "cif",
    "json"
  ],
  "scripts": {
    "build": "tsc --emitDeclarationOnly && webpack-cli --config webpack.config.cjs --mode production"
  },
  "devDependencies": {
    "ts-loader": "^9.5.7",
    "webpack": "^5.106.1",
    "webpack-cli": "^6.0.0"
  }
}
